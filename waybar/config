{
  "layer": "bottom",
  "position": "top",
  "reload_style_on_change": true,

  "modules-left" : [
    "custom/rofi",
    "custom/sleep",
    "custom/spotify",
  ],

  "modules-center": [
    "clock",
  ],

  "modules-right": [
    "custom/wireguard",
    "pulseaudio",
    "network",
    "bluetooth",
    "battery",
    "custom/power",
  ],

  "custom/rofi": {
    "format": "َ°£‡",
    "on-click": "rofi -show drun",
    "tooltip-format": "Launch Application",
  },

  "custom/sleep": {
    "format": "{}",
    "return-type": "json",
    "escape": true,
    "exec-if": "sleep 0.1", // slight delay to sync
    "exec": "~/.config/waybar/scripts/toggle_sleep.sh check",
    "on-click": "~/.config/waybar/scripts/toggle_sleep.sh",
    "interval": 5, // Polling interval to ensure icon stays synced
    "tooltip": true  
  },

  "custom/spotify": {
    "exec": "~/.config/waybar/scripts/player.sh",
    "return-type": "json",
    "interval": 1,
    "format": "{icon} {text}",
    "format-icons": {
        "play": "ïپŒ ",
        "pause": "ïپ‹ ",
    },
    
    "on-click": "playerctl --player=spotify play-pause",
    "on-double-click": "playerctl --player=spotify next",
    "on-triple-right": "playerctl --player=spotify previous",
  },

  "clock": {
    "format": "{:%I:%M %p}",
    "format-alt": "{:%H:%M %p}",
    "tooltip-format": "{:%A %d %B %Y %T}",
    "interval": 1,
  },
  
  "custom/wireguard": {
    "exec": "exec ~/.config/waybar/wireguard-manager/wireguard-manager.sh -s",
    "format": "{icon} {text}",
    "format-icons": {
        "connected": "َ°’ک ",
        "disconnected": "َ°¦‍ ",
    },
    "interval": "once",
    "on-click": "~/.config/waybar/wireguard-manager/wireguard-manager.sh -t && pkill -SIGRTMIN+1 waybar",
    "return-type": "json",
    "signal": 1,
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "î»¨  Muted",
    "format-icons": {
      "headphone": "ï€¥ ",
      "default": ["ï€¦ ", "ï€§ ", "ï€¨ "]
    },
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-click-right": "pwvucontrol",
    "on-scroll-up": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 1%+",
    "on-scroll-down": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 1%-",
    "reverse-scrolling": true,
  },

  "network": {
    "format-wifi": "َ°¤¨  {essid}",
    "format-ethernet": "ï›؟ ",
    "format-disconnected": "َ°¤® ",
    "tooltip-format-wifi": "{essid} ({signalStrength}%)\nâ‡£{bandwidthDownBytes} â‡،{bandwidthUpBytes}",
    "tooltip-format-ethernet": "Wired\nâ‡£{bandwidthDownBytes} â‡،{bandwidthUpBytes}",
    "interval": 3,
    "on-click": "rofi -show wifi -iface wlp98s0"
  },
 
  "bluetooth": {
    "format": "َ°‚² ",
    "format-connected": "َ°‚± ",
    "format-disabled": "َ°‚² ",
    "format-off": "َ°‚² ",
    "tooltip-format": "{device_alias}",
    "on-click": "rofi-bluetooth"
  },
 
  "battery": {
    "format": "{icon} {capacity}%",
    "format-charging": "{icon} {capacity}% ïƒ§ ",
    "format-icons": {
      "default": ["ï‰„ ", "ï‰ƒ ", "ï‰‚ ", "ï‰پ ", "ï‰€ "]
    },
    "interval": 5,
    "states": {
      "warning": 30,
      "critical": 10
    }
  },
 
  "custom/power": {
    "format": "ï€‘ ",
    "on-click": "rofi -show power-menu -modi power-menu:rofi-power-menu",
  },
}
